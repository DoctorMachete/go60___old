            key-positions = <POS_RH_C3R2 POS_RH_C4R2>;
            bindings = <&HTUI_1tap_kp_tpref_350 RA(N0) RBKT>;
            layers = <LAYER__CMKDH LAYER__NUM>;
            require-prior-idle-ms = <100>;
        };

        // ( {
        combo_combo_ParBraceLeft {
            timeout-ms = <60>;
            key-positions = <POS_RH_C2R4 POS_RH_C3R4>;
            bindings = <&HTUI_1tap_kp_tpref LS(LBKT) LS(N9)>;
            layers = <LAYER__CMKDH LAYER__NUM>;
            require-prior-idle-ms = <50>;
        };
    };
};

