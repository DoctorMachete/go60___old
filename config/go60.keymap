/* Automatically generated behavior definitions */
/ {
    behaviors {

        // Layer tap dance behaviors

        ZMK_TD_LAYER(td_LAYER__NUM, 14)
        ZMK_TD_LAYER(td_LAYER_Magic, 26)

        // Called from macroUI_AUTOSHIFT_HOLDTAP so with a single parameter can be used twice, once for the hold and once for the tap.
        HTUI_AUTOSHIFT_shiftkey_kp: HTUI_AUTOSHIFT_shiftkey_kp {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <250>;
            bindings = <&macroUI_AUTOSHIFT_SHIFTKEY>, <&kp>;
            flavor = "tap-preferred";
        };

        // Encapsulating hold-taps for using them in tap-dances
        HTUI_1tap_1tap: HTUI_1tap_1tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <250>;
            bindings = <&macroUI_1tap>, <&macroUI_1tap>;
            flavor = "tap-preferred";
        };

        HTUI_1tap_DeadkeySPC: HTUI_1tap_DeadkeySPC {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <250>;
            bindings = <&macroUI_1tap>, <&macroUI_DeadkeyPar_Space>;
            flavor = "tap-preferred";
        };

        HTUI_1tap_kp_tpref: HTUI_1tap_kp_tpref {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <250>;
            bindings = <&macroUI_1tap>, <&kp>;
            flavor = "tap-preferred";
            quick-tap-ms = <200>;
            require-prior-idle-ms = <0>;
        };

        HTUI_1tap_kp_tpref_350: HTUI_1tap_kp_tpref_350 {
            compatible = "zmk,behavior-hold-tap";
