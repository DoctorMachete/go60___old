// ************************************************************************************************************************************************************************************************
// ************************************************************************************************************************************************************************************************
// ************************************************************************************************************************************************************************************************
// This is repeated here to make sure the lh-listeners are generated in the right order (with _MOUSE last). This way the _MOUSE layer can be put first, which means custom RGB for FAST, WARP, SLOW, FINE will be shown because they're on top of _MOUSE. Otherwise they won't.
// Other way to put it is that I want _MOUSE to be BELLOW the temp layers but at the same time I want it to be generated LAST, and this is the way to achieve it.

// Input Listeners
&cirque_rh_listener {
    input-processors = <&zip_xy_scaler 3 2>, <&zip_temp_layer LAYER__MOUSE 9999>;
    layer__MOUSEFINE {
        layers = <LAYER__MOUSEFINE>;
        input-processors = <&zip_xy_scaler 1 5>, <&zip_temp_layer LAYER__MOUSE 10000>;
    };
    layer__MOUSESLOW {
        layers = <LAYER__MOUSESLOW>;
        input-processors = <&zip_xy_scaler 4 5>, <&zip_temp_layer LAYER__MOUSE 10000>;
    };
    layer__MOUSEFAST {
        layers = <LAYER__MOUSEFAST>;
        input-processors = <&zip_xy_scaler 5 2>, <&zip_temp_layer LAYER__MOUSE 10000>;
    };
    layer__MOUSEWARP {
        layers = <LAYER__MOUSEWARP>;
        input-processors = <&zip_xy_scaler 4 1>, <&zip_temp_layer LAYER__MOUSE 10000>;
    };
};

&cirque_lh_listener {
    input-processors = <&zip_x_scaler 0 1>, <&zip_y_scaler 1 16>, <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>, <&zip_xy_to_scroll_mapper>, <&zip_button_behavior_0>, <&zip_temp_layer LAYER__MOUSE 10000>;
    layer__MOUSEFAST {
        layers = <LAYER__MOUSEFAST>;
        input-processors = <&zip_x_scaler 0 1>, <&zip_y_scaler 1 2>, <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>, <&zip_xy_to_scroll_mapper>, <&zip_button_behavior_1>;
    };
    layer__MOUSEWARP {
        layers = <LAYER__MOUSEWARP>;
        input-processors = <&zip_x_scaler 0 1>, <&zip_y_scaler 2 1>, <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>, <&zip_xy_to_scroll_mapper>, <&zip_button_behavior_2>;
    };
    layer__MOUSE {
        layers = <LAYER__MOUSE>;
        input-processors = <&zip_x_scaler 0 1>, <&zip_y_scaler 1 16>, <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>, <&zip_xy_to_scroll_mapper>, <&zip_button_behavior_3>;
    };
};
