/* Input Listeners */
&cirque_rh_listener {
    input-processors = <&zip_xy_scaler 2 1>, <&zip_temp_layer LAYER__MOUSE 9999>;
    layer__MOUSEFINE {
        layers = <LAYER__MOUSEFINE>;
        input-processors = <&zip_xy_scaler 1 5>, <&zip_temp_layer LAYER__MOUSE 10000>;
    };
    layer__MOUSESLOW {
        layers = <LAYER__MOUSESLOW>;
        input-processors = <&zip_xy_scaler 4 5>, <&zip_temp_layer LAYER__MOUSE 10000>;
    };
    layer__MOUSEFAST {
        layers = <LAYER__MOUSEFAST>;
        input-processors = <&zip_xy_scaler 7 2>, <&zip_temp_layer LAYER__MOUSE 10000>;
    };
    layer__MOUSEWARP {
        layers = <LAYER__MOUSEWARP>;
        input-processors = <&zip_xy_scaler 5 1>, <&zip_temp_layer LAYER__MOUSE 10000>;
    };
};

&cirque_lh_listener {
    input-processors = <&zip_x_scaler 0 1>, <&zip_y_scaler 1 16>, <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>, <&zip_xy_to_scroll_mapper>, <&zip_button_behavior_0>, <&zip_temp_layer LAYER__MOUSE 10000>;
    layer__MOUSE {
        layers = <LAYER__MOUSE>;
        input-processors = <&zip_x_scaler 0 1>, <&zip_y_scaler 1 16>, <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>, <&zip_xy_to_scroll_mapper>, <&zip_button_behavior_1>;
    };
    layer__MOUSEFAST {
        layers = <LAYER__MOUSEFAST>;
        input-processors = <&zip_x_scaler 0 1>, <&zip_y_scaler 1 2>, <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>, <&zip_xy_to_scroll_mapper>, <&zip_button_behavior_2>;
    };
    layer__MOUSEWARP {
        layers = <LAYER__MOUSEWARP>;
        input-processors = <&zip_x_scaler 0 1>, <&zip_y_scaler 2 1>, <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>, <&zip_xy_to_scroll_mapper>, <&zip_button_behavior_3>;
    };
};

/* System behavior and macros */
/ {
    behaviors {
        ZMK_TD_LAYER(lower, LAYER_Lower)
    };
};

/ {
    macros {
        rgb_ug_status_macro: rgb_ug_status_macro {
            label = "RGB_UG_STATUS";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&rgb_ug RGB_STATUS>;
        };
    };
};

/ {
#ifdef BT_DISC_CMD
    behaviors {
        bt_0: bt_0 {
            compatible = "zmk,behavior-tap-dance";
            label = "BT_0";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&bt_select_0>, <&bt BT_DISC 0>;
        };
        bt_1: bt_1 {
            compatible = "zmk,behavior-tap-dance";
            label = "BT_1";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&bt_select_1>, <&bt BT_DISC 1>;
        };
        bt_2: bt_2 {
            compatible = "zmk,behavior-tap-dance";
            label = "BT_2";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&bt_select_2>, <&bt BT_DISC 2>;
        };
        bt_3: bt_3 {
            compatible = "zmk,behavior-tap-dance";
            label = "BT_3";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&bt_select_3>, <&bt BT_DISC 3>;
        };
    };
    macros {
        bt_select_0: bt_select_0 {
            label = "BT_SELECT_0";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&out OUT_BLE>,
                  <&bt BT_SEL 0>;
        };
        bt_select_1: bt_select_1 {
            label = "BT_SELECT_1";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&out OUT_BLE>,
                  <&bt BT_SEL 1>;
        };
        bt_select_2: bt_select_2 {
            label = "BT_SELECT_2";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&out OUT_BLE>,
                  <&bt BT_SEL 2>;
        };
        bt_select_3: bt_select_3 {
            label = "BT_SELECT_3";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&out OUT_BLE>,
                  <&bt BT_SEL 3>;
        };
    };
#else
    macros {
        bt_0: bt_0 {
            label = "BT_0";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&out OUT_BLE>,
                  <&bt BT_SEL 0>;
        };
        bt_1: bt_1 {
            label = "BT_1";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&out OUT_BLE>,
                  <&bt BT_SEL 1>;
        };
        bt_2: bt_2 {
            label = "BT_2";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&out OUT_BLE>,
                  <&bt BT_SEL 2>;
        };
        bt_3: bt_3 {
            label = "BT_3";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&out OUT_BLE>,
                  <&bt BT_SEL 3>;
        };
    };
#endif
};

/ {
    behaviors {
        magic: magic {
            compatible = "zmk,behavior-hold-tap";
            label = "MAGIC_HOLD_TAP";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&mo>, <&rgb_ug_status_macro>;
        };
    };
};


/* Custom Defined Behaviors */
/ {
#define TESTGITHUB  YES

#define SLHSCMMTS    ht_slashes_iniendcomments 0 0                //  /  \     / *  * /
#define BKCDELCTR    ht_backspace_delete_ctrl LCTRL 0             // ⌫ ⌦ ⎈

#define TD_____F1    td_par_F1_F7_F13_F19                              // F1 (tap) F7  (hold)  -  F13 (tap) F19 (hold) 
#define TD_____F2    td_par_F2_F8_F14_F20                              // F2 (tap) F8  (hold)  -  F14 (tap) F20 (hold) 
#define TD_____F3    td_par_F3_F9_F15_F21                              // F3 (tap) F9  (hold)  -  F15 (tap) F21 (hold) 
#define TD_____F4    td_par_F4_F10_F16_F22                             // F4 (tap) F10 (hold)  -  F16 (tap) F22 (hold) 
#define TD_____F5    td_par_F5_F11_F17_F23                             // F5 (tap) F11 (hold)  -  F17 (tap) F23 (hold) 
#define TD_____F6    td_par_F6_F12_F18_F24                             // F6 (tap) F12 (hold)  -  F18 (tap) F24 (hold) 
#define TD_NEWTAB    td_par_newtab_newwindow_newprivatewindow          // new tab (tap) / new window (dbltap) / new private window (dbl tap + hold)

//#define ARROW__U HTUI_arrows LS(K) K

// STICKY
//#define CAPSSHFT    td_OSSHIFT_CAPSLOCK                          // SKSHIFT (tap) + HOLD SHIFT (hold) + CAPS (dbltap) Not used because issues with timings



behaviors {
  #ifdef TESTGITHUB
    swapper: swapper {
