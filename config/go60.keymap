  // ******************************************************************** STICKY LAYER DO


  // , → ;
  mm_comma_semi: mm_comma_semi{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>; 
    bindings = <&kp COMMA>, <&kp SEMI>;   mods = <(MOD_LSFT|MOD_RSFT)>;
  };






  #ifdef TESTGITHUB          // 

  #endif
  


  // *
  // *
  // ******************************************************************** / \   / *  * /  
  //  / → \   ___
  mm_slash_backslash: mm_slash_backslash{
    compatible = "zmk,behavior-mod-morph";
    #binding-cells = <0>;
    bindings = <&kp FSLH>, <&kp NON_US_BSLH>;
    mods = <(MOD_LSFT|MOD_RSFT)>;
  };

  // / * → * /  __
  mm_inicomment_endcomment: mm_inicomment_endcomment{
    compatible = "zmk,behavior-mod-morph";
    #binding-cells = <0>;
    bindings = <&macroUI_1tap_1tap FSLH LS(N8)>, <&macroUI_1tap_1tap LS(N8) FSLH>;
    mods = <(MOD_LSFT|MOD_RSFT)>;
  };

  //  /  \     / *  * /
  ht_slashes_iniendcomments: ht_slashes_iniendcomments{label = "ht_slashes_iniendcomments";  compatible = "zmk,behavior-hold-tap"; #binding-cells = <2>;
    tapping-term-ms = <280>; quick-tap-ms = <125>; flavor = "tap-preferred";
    bindings = <&mm_inicomment_endcomment>, <&mm_slash_backslash>;  
  };

  // *
  // *
  // ******************************************************************** ' ` " ^
  // ' (") → ` (^)
  mm_quoteabcd: mm_quoteabcd{
    compatible = "zmk,behavior-mod-morph";    #binding-cells = <0>;
    bindings = <&HTUI_1tap_1tap LS(SQT) SQT>, <&HTUI_1tap_1tap LS(N6) GRAVE>;    mods = <(MOD_LSFT|MOD_RSFT)>;
  };

  // *
  // *
  // ******************************************************************** ⌫ ⌦ ⎈ 
  //  ⌫ → ⌦
  mm_bckspc_delete: mm_bckspc_delete{
    compatible = "zmk,behavior-mod-morph";
    #binding-cells = <0>;
    bindings = <&kp BSPC>, <&kp DEL>;
    mods = <(MOD_LSFT|MOD_RSFT|MOD_LALT)>;
  };
  //  ⎈⌫ → ⎈⌦
  mm_lcbckspc_lcdelete: mm_lcbckspc_lcdelete{
    compatible = "zmk,behavior-mod-morph";
    #binding-cells = <0>;
    bindings = <&kp LC(BSPC)>, <&kp LC(DEL)>;
    mods = <(MOD_LSFT|MOD_RSFT|MOD_LALT)>;
  };

  //  ⌫ ⌦ ⎈
  ht_backspace_delete_ctrl: ht_backspace_delete_ctrl{label = "ht_backspace_delete_ctrl";  compatible = "zmk,behavior-hold-tap"; #binding-cells = <2>;
    tapping-term-ms = <200>; quick-tap-ms = <125>; flavor = "hold-preferred";
    bindings = <&kp>, <&mm_bckspc_delete>;  
  };
  //  ⌫W ⌦W ⎈  delete word backwards and forward with a single tap or CTRL when hold
  ht_delword_ctrl: ht_delword_ctrl{label = "ht_delword_ctrl";  compatible = "zmk,behavior-hold-tap"; #binding-cells = <2>;
    tapping-term-ms = <200>; quick-tap-ms = <125>; flavor = "hold-preferred";
    bindings = <&kp>, <&mm_lcbckspc_lcdelete>;  
  };


  // *
  // *
  // ******************************************************************** . :   > ≥   
  // , (!) → ; (¡)
  mm_commacexclam_semioexclam: mm_commacexclam_semioexclam{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>; 
    bindings = <&HTUI_1tap_kp_tpref LS(N1) COMMA>, <&HTUI_1tap_kp_tpref RA(N1) SEMI>;   mods = <(MOD_LSFT|MOD_RSFT)>;
  };
  // . (?) → : (¿)
  mm_dotcquest_dbldotoquest: mm_dotcquest_dbldotoquest{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>; 
    bindings = <&HTUI_1tap_kp_tpref LS(FSLH) DOT>, <&HTUI_1tap_kp_tpref RA(FSLH) LS(SEMI)>;   mods = <(MOD_LSFT|MOD_RSFT)>;
  };



  // ******************************************************************** custom_caps_word   NOT 
  caps_word {
    continue-list = <
      UNDERSCORE MINUS LS(MINUS) 
      BACKSPACE DELETE
      N1 N2 N3 N4 N5 N6 N7 N8 N9 N0 SQT LS(SQT)  LS(N9) LS(N0) FSLH BSLH LS(COMMA) LS(SEMI) LS(DOT) LS(BSLH) 
    >;
  };




};
  






};

/* Automatically generated macro definitions */
/ {
    macros {

        // Just shifts the key sent with a parameter. Chained to &HTUI_AUTOSHIFT_shiftkey_kp and &macroUI_AUTOSHIFT_SHIFTKEY
        macroUI_AUTOSHIFT_SHIFTKEY: macroUI_AUTOSHIFT_SHIFTKEY {
            label = "&MACROUI_AUTOSHIFT_SHIFTKEY";
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_press>
                , <&kp LSHFT>
                , <&macro_tap>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>
                , <&macro_release>
                , <&kp LSHFT>;
        };

        macro_release_all_mods: macro_release_all_mods {
            label = "&MACRO_RELEASE_ALL_MODS";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_release>
                , <&kp LGUI>
                , <&kp RGUI>
                , <&kp LALT>
                , <&kp RALT>
                , <&kp LSHFT>
                , <&kp RSHFT>
                , <&kp LCTRL>
                , <&kp RCTRL>;
        };

        macroBothBrace: macroBothBrace {
            label = "&MACROBOTHBRACE";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&kp LS(LBKT)>
                , <&kp LS(RBKT)>;
        };

        macroBothBracket: macroBothBracket {
            label = "&MACROBOTHBRACKET";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&kp LBKT>
                , <&kp RBKT>;
        };

        macroBothPar: macroBothPar {
            label = "&MACROBOTHPAR";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&kp LS(N9)>
                , <&kp LS(N0)>;
        };

        // Reusable macro for sending single taps, often with the purpose of avoiding repeating a tap on hold-taps
        macroUI_1tap: macroUI_1tap {
            label = "&MACROUI_1TAP";
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_tap>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>;
        };

        // For encapsulating two taps with two parameters into a single macro to be used in other behaviors
        macroUI_1tap_1tap: macroUI_1tap_1tap {
            label = "&MACROUI_1TAP_1TAP";
            compatible = "zmk,behavior-macro-two-param";
            #binding-cells = <2>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_tap>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>
                , <&macro_param_2to1>
                , <&kp MACRO_PLACEHOLDER>;
        };

        // To send special characters using the Eurkey layout
        macroUI_EurkeySHFTM: macroUI_EurkeySHFTM {
            label = "&MACROUI_EURKEYSHFTM";
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_tap>
                , <&kp LS(RA(M))>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>;
        };

        // “ ”
        macroBothAsymmetricQuote: macroBothAsymmetricQuote {
            label = "&MACROBOTHASYMMETRICQUOTE";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&kp RA(N9)>
                , <&kp RA(N0)>;
        };
    };
};

/* Automatically generated behavior definitions */
/ {
    behaviors {


        // Called from macroUI_AUTOSHIFT_HOLDTAP so with a single parameter can be used twice, once for the hold and once for the tap.
        HTUI_AUTOSHIFT_shiftkey_kp: HTUI_AUTOSHIFT_shiftkey_kp {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <250>;
            bindings = <&macroUI_AUTOSHIFT_SHIFTKEY>, <&kp>;
            flavor = "tap-preferred";
        };

        // Encapsulating hold-taps for using them in tap-dances
        HTUI_1tap_1tap: HTUI_1tap_1tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <250>;
            bindings = <&macroUI_1tap>, <&macroUI_1tap>;
            flavor = "tap-preferred";
        };

        HTUI_1tap_kp_tpref: HTUI_1tap_kp_tpref {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <250>;
            bindings = <&macroUI_1tap>, <&kp>;
            flavor = "tap-preferred";
            quick-tap-ms = <200>;
            require-prior-idle-ms = <0>;
        };

        HTUI_1tap_kp_tpref_350: HTUI_1tap_kp_tpref_350 {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <350>;
            bindings = <&macroUI_1tap>, <&kp>;
            flavor = "tap-preferred";
            quick-tap-ms = <200>;
            require-prior-idle-ms = <0>;
        };

        HTUI_bothbrace_bothpar: HTUI_bothbrace_bothpar {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <350>;
            bindings = <&macroBothBrace>, <&macroBothPar>;
            flavor = "tap-preferred";
            require-prior-idle-ms = <150>;
        };

        // For sending special Eurkey character from first parameter and a regular one from the second with a macro to avoid repeat keys.
        HTUI_EurShft_1tap: HTUI_EurShft_1tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            bindings = <&macroUI_EurkeySHFTM>, <&macroUI_1tap>;
            flavor = "tap-preferred";
        };

        // For sending special Eurkey character from first parameter and a regular tap from the second
        HTUI_EurShft_EurShft: HTUI_EurShft_EurShft {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            bindings = <&macroUI_EurkeySHFTM>, <&macroUI_EurkeySHFTM>;
            flavor = "tap-preferred";
        };

        // For sending special Eurkey character from first parameter and a regular tap from the second
        HTUI_EurShft_kp: HTUI_EurShft_kp {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <400>;
            bindings = <&macroUI_EurkeySHFTM>, <&kp>;
            flavor = "tap-preferred";
        };

        // Generic hold-tap with quick tap
        HTUI_kp_kp_tpref_250_200_125: HTUI_kp_kp_tpref_250_200_125 {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <250>;
            bindings = <&kp>, <&kp>;
            flavor = "tap-preferred";
            quick-tap-ms = <200>;
            require-prior-idle-ms = <125>;
        };

        // Generic hold-tap with quick tap
        HTUI_kp_kp_tpref_350_200_200: HTUI_kp_kp_tpref_350_200_200 {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <350>;
            bindings = <&kp>, <&kp>;
            flavor = "tap-preferred";
            quick-tap-ms = <200>;
            require-prior-idle-ms = <200>;
        };

        HTUI_kp_sk_tpref_250_0_0: HTUI_kp_sk_tpref_250_0_0 {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <250>;
            bindings = <&kp>, <&sk>;
            flavor = "tap-preferred";
        };

        HTUI_mo_kp_tpref_250_200_50: HTUI_mo_kp_tpref_250_200_50 {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <250>;
            bindings = <&mo>, <&kp>;
            flavor = "tap-preferred";
            quick-tap-ms = <200>;
            require-prior-idle-ms = <50>;
        };

        HTUI_mo_rep_tpref_280_200_0: HTUI_mo_rep_tpref_280_200_0 {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <280>;
            bindings = <&mo>, <&key_repeat>;
            flavor = "tap-preferred";
            quick-tap-ms = <200>;
        };

        // [] “”
        HTUI_bothbracket_bothasymmquot: HTUI_bothbracket_bothasymmquot {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <350>;
            bindings = <&macroBothAsymmetricQuote>, <&macroBothBracket>;
            flavor = "tap-preferred";
            require-prior-idle-ms = <150>;
        };
    };
};

/* Automatically generated combos definitions */
/ {
    combos {
        compatible = "zmk,combos";

        combo_combo_ParBraceBoth {
            timeout-ms = <60>;
            key-positions = <POS_RH_C2R4 POS_RH_C3R4 POS_RH_C4R4>;
            bindings = <&HTUI_bothbrace_bothpar 0 0>;
            layers = <LAYER__CMKDH>;
            require-prior-idle-ms = <100>;
        };

        // <>
        combo_combo_MoreThanLessThan {
            timeout-ms = <60>;
            key-positions = <POS_LH_C4R4 POS_LH_C3R4 POS_LH_C2R4>;
            bindings = <&macroUI_1tap_1tap LS(COMMA) LS(DOT)>;
            layers = <LAYER__CMKDH LAYER__NUM>;
            require-prior-idle-ms = <200>;
        };

        // [] “”
