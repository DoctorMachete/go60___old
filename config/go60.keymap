  sl_long: sticky_key_quick_release {            // to use with NAV/REP ⇒ SKSHIFT/REP
    compatible = "zmk,behavior-sticky-key"; 
    #binding-cells = <1>;
    bindings = <&mo>;                // STICKY LAYER instead of STICKY KEY
    release-after-ms = <3000>;
    quick-release;
    ignore-modifiers;
  }; 
