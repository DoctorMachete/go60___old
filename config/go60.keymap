            layers = <LAYER__NAV>;
            require-prior-idle-ms = <100>;
        };

        // check if this position for & works well enough
        combo_combo_Amper {
            timeout-ms = <60>;
            key-positions = <POS_LH_C2R3 POS_LH_C1R3>;
            bindings = <&kp LS(N7)>;
            layers = <LAYER__CMKDH LAYER__NUM>;
            require-prior-idle-ms = <100>;
        };

        combo_combo_Asterisk {
            timeout-ms = <60>;
