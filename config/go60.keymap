    bindings = <&macroUI_sym_cancelbold>, <&macroUI_sym_cancel>;   
  };

  // ✓✔ → ✕✖
  td_okcancel: td_okcancel{                    
    compatible = "zmk,behavior-tap-dance";  #binding-cells = <0>;  label = "td_okcancel";
    tapping-term-ms = <250>;
    bindings = <&ht_okbold_ok 0 0>, <&ht_cancelbold_cancel 0 0>;
  };

  // *
  // *
  // ******************************************************************** ☐☑☒
  // ☐ → ☑ → ☒
  td_checkbox: td_checkbox{                    
    compatible = "zmk,behavior-tap-dance";  #binding-cells = <0>;  label = "td_checkbox";
    tapping-term-ms = <250>;
    bindings = <&macroUI_sym_chkbxunchecked>, <&macroUI_sym_chkbxok>, <&macroUI_sym_chkbxchecked>;
  };
  // *
  // *
  // ******************************************************************** ⇧⇪⇬
  // ⇧ → ⇪ → ⇬
  td_shft_skshft_caps: td_shft_skshft_caps{                    
    compatible = "zmk,behavior-tap-dance";  #binding-cells = <0>;  label = "td_checkbox";
    tapping-term-ms = <250>;
    bindings = <&macroUI_sym_basic_shift>, <&macroUI_sym_basic_skshift>, <&macroUI_sym_basic_capslock>;
  };
  // *
  // *
  // ******************************************************************** SUPERSCRIPTS
  // it should but RALT is not actually being blocked in the mod-morph. I have to block it here so it doesn't interfere
  // mod-morph inside a hold-tap doesn't work well, it needs to be hold-tap inside a mod-morph

  // NP0
  mm_supsub_kp0: mm_supsub_kp0{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_0>, <&macroUI_sym_sup_0>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_kp0_supsubkp0: mm_n0_supsubn0{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp KP_N0>, <&mm_supsub_kp0>;   mods = <(MOD_RALT)>;  };
  // NP1     // mod-morph inside a hold-tap doesn't work well, it needs to be hold-tap inside a mod-morph
  mm_supsub_kp1: mm_supsub_kp1{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_1>, <&macroUI_sym_sup_1>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_kp1_supsubkp1: mm_kp1_supsubkp1{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&HTUI_1tap_kp_tpref DOT KP_N1>, <&mm_supsub_kp1>;   mods = <(MOD_RALT)>;  };
  // NP2     // mod-morph inside a hold-tap doesn't work well, it needs to be hold-tap inside a mod-morph
  mm_supsub_kp2: mm_supsub_kp2{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_2>, <&macroUI_sym_sup_2>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_kp2_supsubkp2: mm_kp2_supsubkp2{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&HTUI_1tap_kp_tpref COMMA KP_N2>, <&mm_supsub_kp2>;   mods = <(MOD_RALT)>;  };
  // NP3
  mm_supsub_kp3: mm_supsub_kp3{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_3>, <&macroUI_sym_sup_3>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_kp3_supsubkp3: mm_kp3_supsubkp3{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp KP_N3>, <&mm_supsub_kp3>;   mods = <(MOD_RALT)>;  };
  // NP4
  mm_supsub_kp4: mm_supsub_kp4{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_4>, <&macroUI_sym_sup_4>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_kp4_supsubkp4: mm_kp4_supsubkp4{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp KP_N4>, <&mm_supsub_kp4>;   mods = <(MOD_RALT)>;  };
  // NP5
  mm_supsub_kp5: mm_supsub_kp5{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_5>, <&macroUI_sym_sup_5>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_kp5_supsubkp5: mm_kp5_supsubkp5{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp KP_N5>, <&mm_supsub_kp5>;   mods = <(MOD_RALT)>;  };
  // NP6
  mm_supsub_kp6: mm_supsub_kp6{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_6>, <&macroUI_sym_sup_6>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_kp6_supsubkp6: mm_kp6_supsubkp6{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp KP_N6>, <&mm_supsub_kp6>;   mods = <(MOD_RALT)>;  };
  // NP7
  mm_supsub_kp7: mm_supsub_kp7{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_7>, <&macroUI_sym_sup_7>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_kp7_supsubkp7: mm_kp7_supsubkp7{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp KP_N7>, <&mm_supsub_kp7>;   mods = <(MOD_RALT)>;  };
  // NP8
  mm_supsub_kp8: mm_supsub_kp8{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_8>, <&macroUI_sym_sup_8>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_kp8_supsubkp8: mm_kp8_supsubkp8{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp KP_N8>, <&mm_supsub_kp8>;   mods = <(MOD_RALT)>;  };
  // NP9
  mm_supsub_kp9: mm_supsub_kp9{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_9>, <&macroUI_sym_sup_9>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_kp9_supsubkp9: mm_kp9_supsubkp9{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp KP_N9>, <&mm_supsub_kp9>;   mods = <(MOD_RALT)>;  };
  // KP_PLUS
  mm_supsub_kpplus: mm_supsub_kpplus{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_plus>, <&macroUI_sym_sup_plus>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_kpplus_supsubkpplus: mm_kpplus_supsubkpplus{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp KP_PLUS>, <&mm_supsub_kpplus>;   mods = <(MOD_RALT)>;  };
  // KP_MINUS
  mm_supsub_kpminus: mm_supsub_kpminus{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_minus>, <&macroUI_sym_sup_minus>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_kpminus_supsubkpminus: mm_kpminus_supsubkpminus{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp KP_MINUS>, <&mm_supsub_kpminus>;   mods = <(MOD_RALT)>;  };
  // EQUAL
  mm_supsub_equal: mm_supsub_equal{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_equal>, <&macroUI_sym_sup_equal>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_equal_supsubequal: mm_kpequal_supsubequal{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&HTUI_1tap_kp_tpref EQUAL LS(MINUS)>, <&mm_supsub_equal>;   mods = <(MOD_RALT)>;  };
  // (
  mm_supsub_opar: mm_supsub_opar{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_opar>, <&macroUI_sym_sup_opar>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_slashcopy_supsubopar: mm_slashcopy_supsubopar{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&HTUI_1tap_kp_tpref LC(C) KP_SLASH>, <&mm_supsub_opar>;   mods = <(MOD_RALT)>;  };
  // )
  mm_supsub_cpar: mm_supsub_cpar{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_cpar>, <&macroUI_sym_sup_cpar>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_asteriskpaste_supsubcpar: mm_asteriskpaste_supsubcpar{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&HTUI_1tap_kp_tpref LC(V) KP_MULTIPLY>, <&mm_supsub_cpar>;   mods = <(MOD_RALT)>;  };
  // N
  mm_supsub_n: mm_supsub_n{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&macroUI_sym_sub_n>, <&macroUI_sym_sup_n>;   mods = <(MOD_LSFT|MOD_RSFT)>;  };
  mm_n_supsubn: mm_n_supsubn{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp N>, <&mm_supsub_n>;   mods = <(MOD_RALT)>;  };

  mm_A_subA: mm_A_subA{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp A>, <&macroUI_sym_sub_a>;   mods = <(MOD_RALT)>;  };  // A
  mm_E_subE: mm_E_subE{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp E>, <&macroUI_sym_sub_e>;   mods = <(MOD_RALT)>;  };  // E
  mm_O_subO: mm_O_subO{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp O>, <&macroUI_sym_sub_o>;   mods = <(MOD_RALT)>;  };  // O
  mm_X_subX: mm_X_subX{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp X>, <&macroUI_sym_sub_x>;   mods = <(MOD_RALT)>;  };  // X
  mm_H_subH: mm_H_subH{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp H>, <&macroUI_sym_sub_h>;   mods = <(MOD_RALT)>;  };  // H
  mm_K_subK: mm_K_subK{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp K>, <&macroUI_sym_sub_k>;   mods = <(MOD_RALT)>;  };  // K
  mm_L_subL: mm_L_subL{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp L>, <&macroUI_sym_sub_l>;   mods = <(MOD_RALT)>;  };  // L
  mm_M_subM: mm_M_subM{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp M>, <&macroUI_sym_sub_m>;   mods = <(MOD_RALT)>;  };  // M
  mm_P_subP: mm_P_subP{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp P>, <&macroUI_sym_sub_p>;   mods = <(MOD_RALT)>;  };  // P
  mm_S_subS: mm_S_subS{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp S>, <&macroUI_sym_sub_s>;   mods = <(MOD_RALT)>;  };  // S
  mm_T_subT: mm_T_subT{ compatible = "zmk,behavior-mod-morph";   #binding-cells = <0>;     bindings = <&kp T>, <&macroUI_sym_sub_t>;   mods = <(MOD_RALT)>;  };  // T

};
  
};

/* Automatically generated macro definitions */
/ {
    macros {

        // Just shifts the key sent with a parameter. Chained to &HTUI_AUTOSHIFT_shiftkey_kp and &macroUI_AUTOSHIFT_SHIFTKEY
        macroUI_AUTOSHIFT_SHIFTKEY: macroUI_AUTOSHIFT_SHIFTKEY {
            label = "&MACROUI_AUTOSHIFT_SHIFTKEY";
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_press>
                , <&kp LSHFT>
                , <&macro_tap>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>
                , <&macro_release>
                , <&kp LSHFT>;
        };

        // Main Autoshift macro sending a single param to &macroUI_AUTOSHIFT_HOLDTAP
        //
        // Also could be done rectly with a HT but it would require two params each time a key is configured instead of just one.
        macroUI_AUTOSHIFT_HOLDTAP: macroUI_AUTOSHIFT_HOLDTAP {
            label = "&MACROUI_AUTOSHIFT_HOLDTAP";
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_press>
                , <&macro_param_1to1>
                , <&macro_param_1to2>
                , <&HTUI_AUTOSHIFT_shiftkey_kp MACRO_PLACEHOLDER MACRO_PLACEHOLDER>
                , <&macro_pause_for_release>
                , <&macro_release>
                , <&macro_param_1to1>
                , <&macro_param_1to2>
                , <&HTUI_AUTOSHIFT_shiftkey_kp MACRO_PLACEHOLDER MACRO_PLACEHOLDER>;
        };

        macro_ACTIVATE_ALTTAB_LAYER: macro_ACTIVATE_ALTTAB_LAYER {
            label = "&MACRO_ACTIVATE_ALTTAB_LAYER";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_press>
                , <&kp LALT>
                , <&mo LAYER__ALTTAB_RST>
                , <&macro_pause_for_release>
                , <&macro_release>
                , <&kp LALT>
                , <&mo LAYER__ALTTAB_RST>;
        };

        // connect to BT3 and activate CMKDH
        macro_BT_LAPTOP: macro_BT_LAPTOP {
            label = "&MACRO_BT_LAPTOP";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&bt_3>
                , <&to 0>;
        };

        // connect to BT0 and activate CMKDH
        macro_BT_PC: macro_BT_PC {
            label = "&MACRO_BT_PC";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&bt_0>
                , <&to 0>;
        };

        // connect to BT1 and activate ANDROID layer
        macro_BT_SMARTPHONE: macro_BT_SMARTPHONE {
            label = "&MACRO_BT_SMARTPHONE";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&bt_1>
                , <&to LAYER__ANDROID>;
        };

        // connect to BT2 and activate ANDROID layer
        macro_BT_TABLET: macro_BT_TABLET {
            label = "&MACRO_BT_TABLET";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&bt_2>
                , <&to LAYER__ANDROID>;
        };

        // For easily typing Unicode symbols with a single hand.
        macro_NPAD_UNICODE_DISABLE: macro_NPAD_UNICODE_DISABLE {
            label = "&MACRO_NPAD_UNICODE_DISABLE";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_release>
                , <&kp LALT>
                , <&macro_tap>
                , <&tog LAYER__NPAD_UNICODE>;
        };

        // For easily typing Unicode symbols with a single hand.
        macro_NPAD_UNICODE_ENABLE: macro_NPAD_UNICODE_ENABLE {
            label = "&MACRO_NPAD_UNICODE_ENABLE";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_tap>
                , <&tog LAYER__NPAD_UNICODE>
                , <&macro_press>
                , <&kp LALT>;
        };

        macro_release_all_mods: macro_release_all_mods {
            label = "&MACRO_RELEASE_ALL_MODS";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_release>
                , <&kp LGUI>
                , <&kp RGUI>
                , <&kp LALT>
                , <&kp RALT>
                , <&kp LSHFT>
                , <&kp RSHFT>
                , <&kp LCTRL>
                , <&kp RCTRL>;
        };

        // Taps the same key twice In a row.
        macro_REPEAT_KEY: macro_REPEAT_KEY {
            label = "&MACRO_REPEAT_KEY";
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_tap>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>;
        };

        macroBothBrace: macroBothBrace {
            label = "&MACROBOTHBRACE";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&kp LS(LBKT)>
                , <&kp LS(RBKT)>;
        };

        macroBothBracket: macroBothBracket {
            label = "&MACROBOTHBRACKET";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&kp LBKT>
                , <&kp RBKT>;
        };

        macroBothPar: macroBothPar {
            label = "&MACROBOTHPAR";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&kp LS(N9)>
                , <&kp LS(N0)>;
        };

        // Reusable macro for sending single taps, often with the purpose of avoiding repeating a tap on hold-taps
        macroUI_1tap: macroUI_1tap {
            label = "&MACROUI_1TAP";
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_tap>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>;
        };

        // For encapsulating two taps with two parameters into a single macro to be used in other behaviors
        macroUI_1tap_1tap: macroUI_1tap_1tap {
            label = "&MACROUI_1TAP_1TAP";
            compatible = "zmk,behavior-macro-two-param";
            #binding-cells = <2>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_tap>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>
                , <&macro_param_2to1>
                , <&kp MACRO_PLACEHOLDER>;
        };

        // Sends a single tap from the 1st param and activates a sl layer from the 2nd param
        macroUI_1tap_sl: macroUI_1tap_sl {
            label = "&MACROUI_1TAP_SL";
            compatible = "zmk,behavior-macro-two-param";
            #binding-cells = <2>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_tap>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>
                , <&macro_param_2to1>
                , <&sl MACRO_PLACEHOLDER>;
        };

        // A Dead Key is sent as a parameter and the macro sends that key plus a SPC afterwards.
        //
        // This way the dead key can be used with just one parameter in other behaviors.
        //
        macroUI_DeadkeyPar_Space: macroUI_DeadkeyPar_Space {
            label = "&MACROUI_DEADKEYPAR_SPACE";
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_tap>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>
                , <&kp SPACE>;
        };

        macroUI_EurkeyMINUS: macroUI_EurkeyMINUS {
            label = "&MACROUI_EURKEYMINUS";
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_tap>
                , <&kp RA(MINUS)>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>;
        };

        // To send special characters using the Eurkey layout
        macroUI_EurkeySHFTM: macroUI_EurkeySHFTM {
            label = "&MACROUI_EURKEYSHFTM";
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_tap>
                , <&kp LS(RA(M))>
                , <&macro_param_1to1>
                , <&kp MACRO_PLACEHOLDER>;
        };

        macroUI_smart_space_sl: macroUI_smart_space_sl {
            label = "&MACROUI_SMART_SPACE_SL";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&kp SPACE>
                , <&sl LAYER__SMSHFT_TOSHIFT>;
        };

        macroUI_smart_spc_afteri: macroUI_smart_spc_afteri {
            label = "&MACROUI_SMART_SPC_AFTERI";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&kp LS(I)>
                , <&kp SPACE>
                , <&sl LAYER__SMI_I>;
        };

        macroUI_smart_spc_beforei: macroUI_smart_spc_beforei {
            label = "&MACROUI_SMART_SPC_BEFOREI";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&kp SPACE>
                , <&sl LAYER__SMI_I>;
        };

        // ⌫ U+232B
        macroUI_sym_basic_backspc: macroUI_sym_basic_backspc {
            label = "&MACROUI_SYM_BASIC_BACKSPC";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_press>
                , <&kp LALT>
                , <&macro_tap>
                , <&kp KP_PLUS>
                , <&kp KP_N2>
                , <&kp KP_N3>
                , <&kp N2>
                , <&kp B>
                , <&macro_release>
                , <&kp LALT>;
        };

        // ⎗ U+2397
        macroUI_sym_basic_copy: macroUI_sym_basic_copy {
            label = "&MACROUI_SYM_BASIC_COPY";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <0>;
            wait-ms = <0>;
            bindings = <&macro_press>
                , <&kp LALT>
                , <&macro_tap>
