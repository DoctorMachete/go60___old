        };

        // [ “
        combo_combo_BracketAsymmQotLeft {
            timeout-ms = <60>;
            key-positions = <POS_RH_C2R2 POS_RH_C3R2>;
            bindings = <&HTUI_1tap_kp_tpref_350 RA(N9) LBKT>;
            layers = <LAYER__CMKDH LAYER__NUM>;
            require-prior-idle-ms = <100>;
        };

        // ] ”
        combo_combo_BracketAsymmQotRight {
