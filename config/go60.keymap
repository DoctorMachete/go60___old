            bindings = <&kp LS(N2)>;
            layers = <LAYER__CMKDH LAYER__NUM>;
            require-prior-idle-ms = <200>;
        };

        // ) }
        combo_combo_ParBraceRight {
            timeout-ms = <60>;
            key-positions = <POS_RH_C3R4 POS_RH_C4R4>;
            bindings = <&HTUI_1tap_kp_tpref_350 LS(RBKT) LS(N0)>;
            layers = <LAYER__CMKDH LAYER__NUM>;
            require-prior-idle-ms = <50>;
        };

        // < ≤
        combo_combo_LessThan {
            timeout-ms = <60>;
            key-positions = <POS_LH_C4R4 POS_LH_C3R4>;
            bindings = <&HTUI_EurShft_1tap LS(COMMA) LS(COMMA)>;
            layers = <LAYER__CMKDH LAYER__NUM>;
            require-prior-idle-ms = <50>;
        };

        // > ≥
        combo_combo_MoreThan {
            timeout-ms = <60>;
            key-positions = <POS_LH_C3R4 POS_LH_C2R4>;
            bindings = <&HTUI_EurShft_1tap LS(DOT) LS(DOT)>;
            layers = <LAYER__CMKDH LAYER__NUM>;
            require-prior-idle-ms = <50>;
        };

        combo_combo_Percent {
            timeout-ms = <60>;
            key-positions = <POS_LH_C3R2 POS_LH_C2R2>;
            bindings = <&kp LS(N5)>;
            layers = <LAYER__CMKDH LAYER__NUM>;
            require-prior-idle-ms = <100>;
        };

        combo_combo_Pipe {
            timeout-ms = <60>;
            key-positions = <POS_LH_C2R2 POS_LH_C1R2>;
            bindings = <&kp LS(BSLH)>;
            layers = <LAYER__CMKDH LAYER__NUM>;
            require-prior-idle-ms = <100>;
        };

        combo_combo_Hash {
            timeout-ms = <60>;
            key-positions = <POS_RH_C1R2 POS_RH_C2R2>;
            bindings = <&kp LS(N3)>;
            layers = <LAYER__CMKDH LAYER__NUM>;
            require-prior-idle-ms = <100>;
        };

        combo_combo_Insert {
            timeout-ms = <60>;
            key-positions = <POS_RH_C3R2 POS_RH_C4R2>;
