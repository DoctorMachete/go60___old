        };

        combo_TOBASE_L {
            timeout-ms = <70>;
            key-positions = <POS_LH_C6R2 POS_LH_C6R3>;
            bindings = <&to 0>;
        };

        combo_combo_Arroba {
            timeout-ms = <50>;
