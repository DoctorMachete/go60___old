  #define ___ &ug BLK_RGB
  #define _X_ &ug BLK_RGB
  #define DUG &ug DUG_RGB
  #define LAC &ug LAC_RGB
  
  

  //
  // underglow for keyboard locks on the Base layer
  //
  #define BSL &ug_sl BLK_RGB RED_RGB // ScrollLock COLOR_OFF COLOR_ON
  #define BNL &ug_nl BLK_RGB RED_RGB // NumLock    COLOR_OFF COLOR_ON
  #define BCL &ug_cl BLK_RGB RED_RGB // CapsLock   COLOR_OFF COLOR_ON
 
  // same color as the layer editor decorations 
  #define HOM &ug 0x00C3C3    // TEA // for home/main keyr (home keys numpad keys in numpad layer)
  #define MOD &ug 0xBBFCFC // mod-tap keys
  #define XMD &ug 0x97fcfc // mod dedicated
  #define LYR &ug 0xfafa66 // for layer/tap keys
  #define XLY &ug 0xEEEE00 // for layer - dedicated
  #define MUL CHU // for 3+ functions HT or TD keys
  #define SPL PUR // for special keys (magic key, reset, reboot)
  
  

  //
